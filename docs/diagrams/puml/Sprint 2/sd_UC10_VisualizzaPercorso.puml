@startuml sd_UC10_VisualizzaPercorso

title sd UC-10: Visualizza Percorso verso Destinazione

skinparam hyperlinkColor black
skinparam hyperlinkUnderline false

actor ":Utente" as Utente
participant ":App Flutter" as App
participant ":Backend Go" as Backend
participant ":OpenRouteService" as ORS
database ":PostgreSQL" as DB

Utente -> App : inserisciDestinazione(\n  mezzoSelezionato, destinazione)
activate App

App -> Backend : POST /routes\n{ vehicleID, destLat, destLng }
activate Backend

Backend -> DB : findVehicleByID(vehicleID)
activate DB
DB --> Backend : mezzo(posizione, tipo)
deactivate DB

Backend -> DB : findForbiddenZonesAttive()
activate DB
DB --> Backend : zoneVietate[]
deactivate DB

Backend -> Backend : mappaProfiloMezzo(tipo)\n(cycling-regular / driving-car)

Backend -> ORS : GET /directions\n{ profilo, start, end,\n  avoid_polygons: zoneVietate }
activate ORS

alt ORS_non_disponibile
    ORS --> Backend : errore / timeout
    deactivate ORS
    Backend --> App : 200 OK\n{ percorso: linea diretta (fallback) }
else percorso_calcolato
    ORS --> Backend : { geometry, durataMin, distanzaKm }
    deactivate ORS
    Backend --> App : 200 OK\n{ geometry, durataMin, distanzaKm }
end

deactivate Backend

App -> App : disegnaPercorso(geometry)

App --> Utente : mostraPercorso(\n  mezzo -> destinazione)
deactivate App

@enduml
