@startuml sd_UC23_DividiCosto

title sd UC-23: Dividi Costo Corsa Multipla

skinparam hyperlinkColor black
skinparam hyperlinkUnderline false

actor ":Utente" as Utente
actor ":Partecipante" as Part
participant ":App Flutter" as App
participant ":Backend Go" as Backend
participant ":Payment Gateway (Mock)" as Pay
database ":PostgreSQL" as DB

== Generazione del link ==

Utente -> App : generaLinkPagamento(rideID)\n(al termine di una corsa multipla)
activate App

App -> Backend : POST /rides/{id}/payment-link
activate Backend

Backend -> DB : findCorsaMultipla(rideID)
activate DB
DB --> Backend : costoTotale, numPartecipanti
deactivate DB

Backend -> Backend : quota = costoTotale / numPartecipanti\nvalidUntil = now + 10 min

Backend -> DB : insertPaymentLink(\n  rideID, totalAmount, participants,\n  amountPerHead, validUntil, "active")
activate DB
DB --> Backend : linkID
deactivate DB

Backend --> App : 201 Created\n{ link, quota, scadenza }
deactivate Backend
App --> Utente : mostraLinkCondivisibile
deactivate App

== Pagamento di una quota ==

Part -> Backend : POST /payment-links/{id}/pay\n{ carta / PayPal }
activate Backend

alt link_scaduto
    Backend --> Part : 410 Gone\n{ error: "link scaduto" }
    note over Utente : l'utente puo' rigenerare un nuovo link
else link_valido
    Backend -> Pay : addebita(quota)
    activate Pay
    Pay --> Backend : ok
    deactivate Pay
    Backend -> DB : registraPagamento(linkID)\naccreditaCredito(prenotante, quota)
    activate DB
    DB --> Backend : ok
    deactivate DB
    Backend --> Part : 200 OK\n{ esito pagamento }
end

deactivate Backend

@enduml
