@startuml sd_UC16_PrenotazioneMultipla

title sd UC-16: Prenotazione Multipla

skinparam hyperlinkColor black
skinparam hyperlinkUnderline false

actor ":Utente" as Utente
participant ":App Flutter" as App
participant ":Backend Go" as Backend
database ":PostgreSQL" as DB

Utente -> App : selezionaMezzi(mezzi[])\n(max 5, bici/scooter, entro 100 m)

App -> App : verificaVincoliLato Client(\n  max 5, raggio 100 m, tipologia)

App -> Backend : POST /bookings/multi\n{ vehicleIDs[] }

Backend -> DB : findVehicles(vehicleIDs)
DB --> Backend : mezzi[]

alt ~[vincoli_non_rispettati~]
    Backend --> App : 409 Conflict\n{ error: "vincoli non rispettati" }
    App --> Utente : mostraErrore(\n  "Selezione non valida")
else ~[vincoli_ok~]
    Backend -> DB : insertBookings(\n  userID, vehicleIDs[], scadenza 15 min)\nupdateVehiclesStato("prenotato")
    DB --> Backend : bookingIDs[]
    Backend --> App : 201 Created\n{ bookings[] }
    App -> App : avviaCountdownScadenza(15 min)
    App --> Utente : mostraPrenotazioniMultiple(\n  sblocco simultaneo)
end

@enduml
