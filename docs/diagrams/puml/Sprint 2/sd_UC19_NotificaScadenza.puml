@startuml sd_UC19_NotificaScadenza

title sd UC-19: Notifica Scadenza Prenotazione

skinparam hyperlinkColor black
skinparam hyperlinkUnderline false

actor ":Utente" as Utente
participant ":App Flutter" as App
participant ":Notifiche locali" as Notif
participant ":Backend Go" as Backend

note over App : alla creazione della prenotazione\nl'app conosce expiresAt (createdAt + 15 min)

App -> Notif : pianificaNotificaLocale(\n  expiresAt - 3 min)
activate Notif

... 12 minuti dopo (3 min alla scadenza) ...

Notif --> Utente : notifica locale\n"Prenotazione in scadenza tra 3 min"\n[ Vai al mezzo | Annulla ]
deactivate Notif

alt utente_annulla
    Utente -> App : annullaPrenotazione()
    activate App
    App -> Backend : POST /bookings/{id}/cancel
    activate Backend
    Backend --> App : 200 OK
    deactivate Backend
    App --> Utente : mostraPrenotazioneAnnullata()
    deactivate App
else utente_procede
    Utente -> App : vaiAlMezzo()
    activate App
    App --> Utente : mostraPercorso / sblocco
    deactivate App
else nessuna_azione
    note over App, Backend : alla scadenza (15 min) la prenotazione\ndecade automaticamente e il mezzo torna disponibile
end

@enduml
