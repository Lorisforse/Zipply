@startuml sd_UC09_VisualizzaZoneVietate

title sd UC-09: Visualizza Zone Vietate

skinparam hyperlinkColor black
skinparam hyperlinkUnderline false

actor ":Utente" as Utente
participant ":App Flutter" as App
participant ":Backend Go" as Backend
database ":PostgreSQL" as DB

Utente -> App : apriZoneVietate()

App -> App : verificaTokenValido()

alt ~[token_non_valido~]
    App --> Utente : reindirizzaLogin()
else ~[token_valido~]

    App -> App : recuperaPosizioneGPS()

    App -> Backend : GET /zones/restricted\n{ lat, lng, radius }

    Backend -> DB : findZoneVietate(\n  lat, lng, radius)
    DB --> Backend : zoneVietate[]

    Backend -> DB : findZoneDesignate(\n  lat, lng, radius)
    DB --> Backend : zoneDesignate[]

    Backend --> App : 200 OK\n{ zoneVietate[],\n  zoneDesignate[] }

    App -> App : renderizzaOverlayZone(\n  zoneVietate[],\n  zoneDesignate[])

    App --> Utente : mostraMappaConZone(\n  overlayRosso: zone_vietate,\n  overlayVerde: zone_designate)

    alt ~[utente_sposta_o_zooma~]
        Utente -> App : aggiornaAreaVisibile(\n  nuoviBounds)
        App -> Backend : GET /zones/restricted\n{ lat, lng, radius }
        Backend -> DB : findZoneVietate(\n  lat, lng, radius)
        DB --> Backend : zoneVietate[]
        Backend -> DB : findZoneDesignate(\n  lat, lng, radius)
        DB --> Backend : zoneDesignate[]
        Backend --> App : 200 OK\n{ zoneVietate[],\n  zoneDesignate[] }
        App -> App : aggiornаOverlayZone(\n  zoneVietate[],\n  zoneDesignate[])
        App --> Utente : mostraMappaAggiornata()
    end

end

@enduml