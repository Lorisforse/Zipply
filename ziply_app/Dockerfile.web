# Dashboard web Ziply (Flutter Web) servita da nginx.
# Usata dallo stack locale "tutto pronto" (docker-compose.local.yml).
#
# Stage 1 — build della web app. Flutter >= 3.27 (il codice usa Color.withValues).
FROM ghcr.io/cirruslabs/flutter:3.27.1 AS build

WORKDIR /app

# Cache delle dipendenze: copia prima i soli pubspec.
COPY pubspec.* ./
RUN flutter pub get

COPY . .

# BASE_URL relativo (/api) → le chiamate restano sull'origine da cui è servita
# la pagina (same-origin): nginx inoltra /api/ al backend. Override possibile:
#   docker build --build-arg BASE_URL=https://miohost/ziply/api ...
ARG BASE_URL=/api
ARG BASE_HREF=/
RUN flutter build web --release --base-href=$BASE_HREF --dart-define=BASE_URL=$BASE_URL

# Stage 2 — nginx serve la build statica e fa da reverse proxy verso il backend.
FROM nginx:1.27-alpine

COPY --from=build /app/build/web /usr/share/nginx/html
COPY nginx.web.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
